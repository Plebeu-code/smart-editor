# ─────────────────────────────────────────────────────────────────────────────
# SmartEditor — Environment Variables
# Copy this file to .env.local and fill in your keys
# ─────────────────────────────────────────────────────────────────────────────

# OpenAI — used for Whisper transcription and TTS voice generation
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Anthropic — used for Claude scene analysis and dubbing translation
# Get your key at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...
